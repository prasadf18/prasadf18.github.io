  <!-- 🔥 Naruto Floating Widget -->
  <div class="naruto-widget">
    <img src="/gif/naruto.gif" alt="Naruto vibe" />
    <audio id="bgMusic" loop>
      <source src="/mp3/naruto.mp3" type="audio/mpeg" />
    </audio>
  </div>

  <style>
    .naruto-widget {
      position: fixed;
      bottom: 16px;
      right: 16px;
      width: 90px;
      height: 90px;
      z-index: 99999;
      cursor: pointer;
    }

    .naruto-widget img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 14px;
      box-shadow: 0 0 18px rgba(0, 0, 0, 0.5);
      transition: transform 0.2s ease;
    }

    .naruto-widget img:hover {
      transform: scale(1.08);
    }
  </style>

  <script is:inline>
    const init = () => {
      const audio = document.getElementById("bgMusic");
      const widget = document.querySelector(".naruto-widget");

      if (!audio || !widget) return;

      audio.volume = 0.6;

      let isPlaying = false;

      audio.play().catch(() => {});

      widget.addEventListener("click", async () => {
        try {
          if (!isPlaying) {
            await audio.play();
            isPlaying = true;
          } else {
            audio.pause();
            isPlaying = false;
          }
        } catch (e) {
          console.log("Audio error:", e);
        }
      });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
  </script>
</Layout>