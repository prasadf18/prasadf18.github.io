---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const PAGE_SIZE = 2; // ✅ MOVE HERE (fixes runtime scope issue)

  const posts = await getCollection("blog");

  posts.sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
  );

  const totalPages = Math.ceil(posts.length / PAGE_SIZE);

  return Array.from({ length: totalPages }).map((_, i) => ({
    params: { page: String(i + 1) },
    props: {
      posts,
      page: i + 1,
      totalPages,
    },
  }));
}

const { posts, page, totalPages } = Astro.props;

const PAGE_SIZE = 2; // (safe to repeat here too)

const start = (page - 1) * PAGE_SIZE;
const paginatedPosts = posts.slice(start, start + PAGE_SIZE);
---

<Layout title={`Page ${page}`}>

  {paginatedPosts.map((post) => (
    <p>
      {post.data.date.toISOString().slice(0, 10)} —{" "}
      <a href={`/blog/${post.slug}/`}>
        {post.data.title}
      </a>
    </p>
  ))}

  <div style="display:flex; justify-content:flex-end; margin-top:20px;">
    {page < totalPages && (
      <a href={`/page/${page + 1}`} style="font-size:24px;">
        &gt;
      </a>
    )}
  </div>

</Layout>