---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");

// sort latest first
posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// take only first 2
const latestPosts = posts.slice(0, 2);
---

<Layout title="Home">

  <!-- ═══════════════════════════════════════════
       EFFECT 7: FALLING KANJI CANVAS (background)
  ════════════════════════════════════════════ -->
  <canvas id="kanji-rain"></canvas>

  <!-- ═══════════════════════════════════════════
       EFFECT 2: INK CURSOR TRAIL CANVAS
  ════════════════════════════════════════════ -->
  <canvas id="ink-trail"></canvas>

  <!-- MAIN CONTENT -->
  <div id="main-content">

    <!-- EFFECT 4: Glitch text on name -->
    <h1 style="font-size: 1.8rem;">
      <span id="glitch-name" data-text="Prasad Firame">Prasad Firame</span>
      <span class="cursor">_</span>
    </h1>

    <p>
      I'm an engineer and writer focused on building simple, fast,
      and scalable software systems. I care about understanding how
      things work under the hood, not just using them.
    </p>

    <p>
      Most of my time goes into exploring distributed systems,
      data engines, and developer tools , the systems that quietly
      power everything at scale.
    </p>

    <p>
      I like breaking complex systems into simple ideas and turning
      them into code, writing, and experiments.
    </p>

    <!-- IMAGE + QUOTES -->
    <div class="image-wrapper">

      <!-- EFFECT 6: Brush stroke underline on quote -->
      <p class="vagabond-quote top">
        &gt; Welcome to my domain,<br/>
        &gt; Throughout heaven and earth, I alone am the honored one..
      </p>

      <img
        id="musashi-image"
        src="/musashi-sitting.jpg"
        alt="Musashi sitting"
        class="hero-image"
      />

      <p class="vagabond-quote bottom brush-reveal">
        &gt; all truly strong people are kind.
      </p>

    </div>

    <!-- AUDIO -->
    <audio id="bgMusic" loop>
      <source src="/mp3/ninjabg.mp3" type="audio/mpeg" />
    </audio>

    <p>
      Read my Origin story
      <a href="/origin-story" class="slash-link hover-sound">here</a>
    </p>

    <!-- WRITE UPS -->
    <!-- EFFECT 6: brush stroke on section heading -->
    <p style="margin-top:2rem; font-size:0.95rem;" class="post-date brush-reveal">
      write-ups
    </p>

    {latestPosts.map((post) => (
      <p>
        <span class="post-date">
          {post.data.date.toISOString().slice(0, 10)}
        </span>

        {" "}—{" "}

        <a href={`/blog/${post.id.replace(".md", "")}/`} class="slash-link hover-sound">
          {post.data.title}
        </a>
      </p>
    ))}

    <!-- NAVIGATION -->
    {posts.length > 2 && (
      <div
        style="
          display:flex;
          justify-content:flex-end;
          align-items:center;
          gap:15px;
          margin-top:10px;
        "
      >
        <a href="/" style="font-size:24px; opacity:0.6;" class="slash-link hover-sound">
          &lt;
        </a>

        <a href="/page/1" style="font-size:24px;" class="slash-link hover-sound">
          &gt;
        </a>
      </div>
    )}

    <!-- FOOTER -->
    <p style="margin-top:2rem;">
      <a href="https://x.com/rev_proxy" class="slash-link hover-sound">x/twitter</a>
      ·
      <a href="mailto:pfirame18@gmail.com" class="hover-sound">email</a>
      ·
      <a href="https://github.com/prasadf18" class="hover-sound">github</a>
      ·
      <a href="/resume.pdf" target="_blank" class="hover-sound">📄 CV</a>
    </p>

  </div><!-- /main-content -->

</Layout>

<!-- ═══════════════════════════════════════════════════════════════
     ALL ANIME EFFECTS SCRIPT
════════════════════════════════════════════════════════════════ -->
<script is:inline>

/* ─────────────────────────────────────────────
   EFFECT 7: FALLING KANJI RAIN
───────────────────────────────────────────── */
(function kanjiRain() {
  const canvas  = document.getElementById("kanji-rain");
  const ctx     = canvas.getContext("2d");
  const kanji   = "斬道侍刀風雷天地剣武士魂炎水忍鬼龍虎猛力夢幻影";

  let cols, drops;

  function resize() {
    canvas.width  = window.innerWidth;
    canvas.height = window.innerHeight;
    cols  = Math.floor(canvas.width / 22);
    drops = Array(cols).fill(1);
  }

  resize();
  window.addEventListener("resize", resize);

  function draw() {
    ctx.fillStyle = "rgba(0,0,0,0.045)";
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    ctx.fillStyle = "rgba(113,113,122,0.18)";
    ctx.font      = "14px serif";

    drops.forEach((y, i) => {
      const ch = kanji[Math.floor(Math.random() * kanji.length)];
      ctx.fillText(ch, i * 22, y * 22);
      if (y * 22 > canvas.height && Math.random() > 0.975) drops[i] = 0;
      drops[i]++;
    });
  }

  setInterval(draw, 55);
})();


/* ─────────────────────────────────────────────
   EFFECT 2: INK SPLATTER CURSOR TRAIL
───────────────────────────────────────────── */
(function inkTrail() {
  const canvas = document.getElementById("ink-trail");
  const ctx    = canvas.getContext("2d");

  canvas.width  = window.innerWidth;
  canvas.height = window.innerHeight;
  window.addEventListener("resize", () => {
    canvas.width  = window.innerWidth;
    canvas.height = window.innerHeight;
  });

  const particles = [];

  window.addEventListener("mousemove", (e) => {
    const count = 2 + Math.floor(Math.random() * 2);
    for (let i = 0; i < count; i++) {
      particles.push({
        x:     e.clientX + (Math.random() - 0.5) * 10,
        y:     e.clientY + (Math.random() - 0.5) * 10,
        r:     1 + Math.random() * 3,
        alpha: 0.6 + Math.random() * 0.4,
        vx:   (Math.random() - 0.5) * 1.2,
        vy:   (Math.random() - 0.5) * 1.2,
        life:  1.0,
        decay: 0.025 + Math.random() * 0.02
      });
    }
  });

  function animate() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    for (let i = particles.length - 1; i >= 0; i--) {
      const p = particles[i];
      p.x    += p.vx;
      p.y    += p.vy;
      p.life -= p.decay;

      if (p.life <= 0) { particles.splice(i, 1); continue; }

      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(180,160,120,${p.life * p.alpha * 0.5})`;
      ctx.fill();
    }

    requestAnimationFrame(animate);
  }

  animate();
})();


/* ─────────────────────────────────────────────
   EFFECT 4: GLITCH TEXT ON NAME
───────────────────────────────────────────── */
(function glitchName() {
  const el      = document.getElementById("glitch-name");
  const original= el.dataset.text;
  const chars   = "斬道侍刀ア#@!%イウエオABCDEF0123456789";
  let   timer   = null;

  function glitch() {
    let iterations = 0;
    clearInterval(timer);
    timer = setInterval(() => {
      el.textContent = original
        .split("")
        .map((ch, idx) => {
          if (ch === " ") return " ";
          if (idx < iterations) return original[idx];
          return chars[Math.floor(Math.random() * chars.length)];
        })
        .join("");

      iterations += 0.4;
      if (iterations >= original.length) {
        el.textContent = original;
        clearInterval(timer);
      }
    }, 40);
  }

  el.addEventListener("mouseenter", glitch);

  // auto-glitch once on load
  setTimeout(glitch, 800);
})();


/* ─────────────────────────────────────────────
   EFFECT 6: BRUSH STROKE SCROLL REVEAL
───────────────────────────────────────────── */
(function brushReveal() {
  const targets = document.querySelectorAll(".brush-reveal");

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add("brush-active");
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.6 });

  targets.forEach(t => observer.observe(t));
})();


/* ─────────────────────────────────────────────
   EFFECT 1: KATANA SLASH PAGE TRANSITION
───────────────────────────────────────────── */
(function katanaSlash() {
  const slash = document.createElement("div");
  slash.id = "katana-slash";
  document.body.appendChild(slash);

  document.querySelectorAll("a.slash-link").forEach(link => {
    link.addEventListener("click", (e) => {
      const href = link.getAttribute("href");
      if (!href || href.startsWith("mailto") || href.startsWith("http")) return;

      e.preventDefault();
      slash.classList.add("slash-active");

      setTimeout(() => {
        window.location.href = href;
      }, 420);
    });
  });
})();


/* ─────────────────────────────────────────────
   EFFECT 3: SAKURA / ASH PETALS (grayscale)
───────────────────────────────────────────── */
(function ashPetals() {
  const count = 18;

  for (let i = 0; i < count; i++) {
    const petal = document.createElement("div");
    petal.className = "ash-petal";

    const size  = 4 + Math.random() * 7;
    const left  = Math.random() * 100;
    const delay = Math.random() * 12;
    const dur   = 8 + Math.random() * 10;
    const drift = (Math.random() - 0.5) * 120;

    petal.style.cssText = `
      left: ${left}%;
      width: ${size}px;
      height: ${size * 0.6}px;
      animation-delay: ${delay}s;
      animation-duration: ${dur}s;
      --drift: ${drift}px;
    `;

    document.body.appendChild(petal);
  }
})();


/* ─────────────────────────────────────────────
   EFFECT 17: SWORD SHEATH HOVER SOUND
   Synthesised via Web Audio — no file needed
───────────────────────────────────────────── */
(function hoverSound() {
  const AC = window.AudioContext || window.webkitAudioContext;
  if (!AC) return;
  let ctx;

  function playSwish() {
    // lazy-init AudioContext on first interaction (browser policy)
    if (!ctx) ctx = new AC();

    const sampleRate = ctx.sampleRate;
    const duration   = 0.18; // seconds
    const buf        = ctx.createBuffer(1, sampleRate * duration, sampleRate);
    const data       = buf.getChannelData(0);

    // white noise shaped with fast exponential decay → breathy swish
    for (let i = 0; i < data.length; i++) {
      const t  = i / sampleRate;
      data[i]  = (Math.random() * 2 - 1) * Math.exp(-t * 28) * 0.22;
    }

    const src    = ctx.createBufferSource();
    src.buffer   = buf;

    // highpass filter strips low rumble, keeps only the "shk" texture
    const filter = ctx.createBiquadFilter();
    filter.type  = "highpass";
    filter.frequency.value = 800;

    const gain   = ctx.createGain();
    gain.gain.value = 0.4;

    src.connect(filter);
    filter.connect(gain);
    gain.connect(ctx.destination);
    src.start();
  }

  document.querySelectorAll(".hover-sound").forEach(el => {
    el.addEventListener("mouseenter", playSwish);
  });
})();


/* ─────────────────────────────────────────────
   MUSIC — scroll + click fallback
───────────────────────────────────────────── */
(function music() {
  const image = document.getElementById("musashi-image");
  const audio = document.getElementById("bgMusic");
  let   played = false;

  const hint = document.createElement("p");
  hint.id    = "music-hint";
  hint.textContent = "[ click image to enable music ]";
  hint.style.cssText =
    "text-align:center;font-size:0.75rem;color:#71717a;margin-top:0.4rem;opacity:0.7;cursor:pointer;";
  image.parentNode.insertBefore(hint, image.nextSibling);

  function tryPlay() {
    if (!played) {
      audio.play()
        .then(() => {
          played = true;
          const h = document.getElementById("music-hint");
          if (h) h.style.display = "none";
        })
        .catch(() => {});
    }
  }

  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) tryPlay(); });
  }, { threshold: 0.6 });

  obs.observe(image);
  image.addEventListener("click", tryPlay);
  document.addEventListener("click", tryPlay, { once: true });
})();

</script>

<!-- ═══════════════════════════════════════════════════════════════
     STYLES
════════════════════════════════════════════════════════════════ -->
<style>

/* ── KANJI RAIN CANVAS ── */
#kanji-rain {
  position: fixed;
  top: 0; left: 0;
  width: 100vw; height: 100vh;
  pointer-events: none;
  z-index: 0;
  opacity: 0.55;
}

/* ── INK TRAIL CANVAS ── */
#ink-trail {
  position: fixed;
  top: 0; left: 0;
  width: 100vw; height: 100vh;
  pointer-events: none;
  z-index: 9999;
}

/* ── MAIN CONTENT above canvases ── */
#main-content {
  position: relative;
  z-index: 10;
}

/* ══════════════════════════════════
   EFFECT 1: KATANA SLASH TRANSITION
══════════════════════════════════ */
#katana-slash {
  position: fixed;
  top: -10%;
  left: -5%;
  width: 8px;
  height: 120vh;
  background: linear-gradient(
    to bottom,
    transparent 0%,
    rgba(255,255,255,0.0) 10%,
    rgba(230,220,200,0.9) 50%,
    rgba(255,255,255,0.0) 90%,
    transparent 100%
  );
  transform: rotate(15deg) translateX(-100px);
  pointer-events: none;
  z-index: 99998;
  opacity: 0;
  transition: none;
}

#katana-slash.slash-active {
  animation: katana-strike 0.4s ease-in forwards;
}

@keyframes katana-strike {
  0%   { opacity: 0;   transform: rotate(15deg) translateX(-100px); }
  15%  { opacity: 1;   transform: rotate(15deg) translateX(10vw); }
  40%  { opacity: 1;   transform: rotate(15deg) translateX(50vw); }
  70%  { opacity: 0.6; transform: rotate(15deg) translateX(100vw); }
  100% { opacity: 0;   transform: rotate(15deg) translateX(120vw); }
}

/* ══════════════════════════════════
   EFFECT 3: ASH PETALS
══════════════════════════════════ */
.ash-petal {
  position: fixed;
  top: -20px;
  border-radius: 50% 20% 50% 20%;
  background: rgba(160,150,140,0.25);
  pointer-events: none;
  z-index: 5;
  animation: petal-fall linear infinite;
  transform-origin: center;
}

@keyframes petal-fall {
  0%   {
    top: -20px;
    transform: translateX(0) rotate(0deg);
    opacity: 0;
  }
  5%   { opacity: 1; }
  90%  { opacity: 0.4; }
  100% {
    top: 100vh;
    transform: translateX(var(--drift)) rotate(540deg);
    opacity: 0;
  }
}

/* ══════════════════════════════════
   EFFECT 4: GLITCH NAME
══════════════════════════════════ */
#glitch-name {
  cursor: default;
  display: inline-block;
  transition: color 0.1s;
}

#glitch-name:hover {
  text-shadow:
    2px 0 rgba(255,50,50,0.3),
   -2px 0 rgba(50,200,255,0.3);
}

/* ══════════════════════════════════
   EFFECT 6: BRUSH STROKE REVEAL
══════════════════════════════════ */
.brush-reveal {
  position: relative;
  display: inline-block;
}

.brush-reveal::after {
  content: "";
  position: absolute;
  bottom: -3px;
  left: 0;
  height: 2px;
  width: 0%;
  background: linear-gradient(
    to right,
    transparent,
    rgba(160,140,100,0.7) 20%,
    rgba(180,160,120,0.9) 50%,
    rgba(160,140,100,0.7) 80%,
    transparent
  );
  border-radius: 2px;
  transition: width 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  filter: blur(0.5px);
}

.brush-reveal.brush-active::after {
  width: 100%;
}

/* ══════════════════════════════════
   ORIGINAL STYLES
══════════════════════════════════ */
.image-wrapper {
  width: 82%;
  margin: 2rem auto;
  display: flex;
  flex-direction: column;
}

.hero-image {
  width: 100%;
  display: block;
  border-radius: 4px;
  opacity: 0.92;
  cursor: pointer;

  filter: grayscale(100%) contrast(115%) brightness(0.92);
  transition: transform 0.25s ease, opacity 0.25s ease;
}

.hero-image:hover {
  opacity: 1;
  transform: scale(1.01);
}

.vagabond-quote {
  margin: 0.8rem 0;
  color: #71717a !important;
  font-size: 0.88rem;
  font-style: italic;
  opacity: 0.9;
  line-height: 1.5;
}

.vagabond-quote.top  { text-align: left; }
.vagabond-quote.bottom { text-align: right; }

</style>